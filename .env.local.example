# ===========================================
# Thyrocare Aarogyam Centre - Backend Config
# ===========================================
# Copy this file as .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Email Service Configuration (for booking notifications)
# For Gmail: Use an App Password (not your regular password)
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# 2. Generate a new App Password for "Mail"
# 3. Paste it below
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# The email address that receives booking notifications
# Defaults to EMAIL_USER if not set
OWNER_EMAIL=thyrocare.siddipet@gmail.com

# Base URL of the website (used for CORS and callbacks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
